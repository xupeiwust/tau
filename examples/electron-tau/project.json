{
  "name": "example-electron",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "examples/electron-tau",
  "projectType": "application",
  "tags": ["scope:example", "type:app"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "{projectRoot}",
        "command": "electron-vite dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "electron-vite build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm exec electron .",
        "env": {
          "NODE_ENV": "production"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vitest run --config vitest.config.ts --watch=false"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "playwright test"
      }
    }
  }
}
