{
  "name": "api-extractor",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-extractor",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "extract-replicad": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/extract-replicad-api.ts",
        "cwd": "libs/api-extractor"
      }
    },
    "extract-jscad": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/extract-jscad-types.ts",
        "cwd": "libs/api-extractor"
      }
    },
    "extract-kcl": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/extract-kcl-api.ts",
        "cwd": "libs/api-extractor"
      }
    },
    "extract-manifold": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/extract-manifold-types.ts",
        "cwd": "libs/api-extractor"
      }
    },
    "extract-opencascade": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/extract-opencascade-types.ts",
        "cwd": "libs/api-extractor"
      }
    }
  }
}
