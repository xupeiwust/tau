{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["node", "vitest/importMeta", "vitest"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2024"],
    "target": "ESNext",
    "paths": {
      "#*": ["./src/*"]
    }
  },
  "include": [
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js"
  ],
  "exclude": ["src/**/*.test-d.ts"]
}
