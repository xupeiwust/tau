{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/typetest",
    "types": ["node", "vitest/importMeta", "vitest"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024"],
    "target": "ESNext",
    "paths": {
      "#*": ["./src/*"],
      "opencascade.js": ["./src/generated/opencascade/modules/opencascade.js/index.d.ts"],
      "opencascade": ["./src/generated/opencascade/modules/opencascade/index.d.ts"],
      "replicad": ["./src/generated/replicad/modules/replicad/index.d.ts"],
      "replicad-opencascadejs": ["./src/generated/replicad/replicad-opencascadejs-stub.d.ts"],
      "opentype.js": ["./src/generated/replicad/opentype-stub.d.ts"],
      "@jscad/modeling": ["./src/generated/jscad/modules/@jscad/modeling/index.d.ts"],
      "@jscad/modeling/*": ["./src/generated/jscad/modules/@jscad/modeling/*/index.d.ts"],
      "manifold-3d": ["./src/generated/manifold/modules/manifold-3d/index.d.ts"],
      "manifold-3d/*": ["./src/generated/manifold/modules/manifold-3d/*/index.d.ts"]
    }
  },
  "include": ["src/**/*.test-d.ts", "src/**/*.d.ts", "src/**/*.ts"]
}
