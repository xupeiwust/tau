{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/lib",
    "module": "NodeNext",
    "types": ["node"],
    "target": "ESNext",
    "paths": {
      "#*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.test-d.ts"]
}
