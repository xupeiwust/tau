# =============================================================================
# .dockerignore — used by apps/api/Dockerfile (the only Dockerfile in the repo).
#
# Build context is the repo root. The API Docker build uses COPY . . to ingest
# the full Nx monorepo, so only exclude items that the build doesn't need.
# =============================================================================

# -- Version control ----------------------------------------------------------
.git
.gitignore
.gitattributes

# -- External dependency repos (86 GB locally, gitignored but not dockerignored) --
repos

# -- Benchmark and report artifacts (937 MB of HTML/JSON/GLB outputs) --------
apps/api/reports
packages/runtime/reports
packages/runtime/occt-reports

# -- E2E test projects (trigger @nx/playwright plugin in Nx project graph) ----
apps/ui-e2e
apps/api-e2e

# -- Documentation (not needed at build time) ---------------------------------
docs

# -- CI / tooling / editor config ---------------------------------------------
.github
scripts
.cursor
.vscode
.idea
.editorconfig
.eslintcache
.oxlintcache
.prettierrc*
.lintstagedrc*
.husky

# -- Nx caches and workspace data --------------------------------------------
**/.nx/cache
**/.nx/workspace-data

# -- Build artifacts (produced locally, not needed in fresh Docker build) ------
**/build
**/dist
**/out-tsc
**/*.tsbuildinfo

# -- Dependencies (installed fresh inside Docker) -----------------------------
**/node_modules

# -- Environment variables (secrets, never ship) ------------------------------
**/.env
**/.env.*

# -- Test files (not needed in production images) -----------------------------
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/*.test-d.ts
**/__tests__
**/__mocks__
**/coverage

# -- Vite timestamp files ----------------------------------------------------
**/vite.config.*.timestamp*

# -- Fly.io config (injected via --config flag, not COPY) ---------------------
fly.*.toml

# -- Miscellaneous ------------------------------------------------------------
**/.cache
**/pruned
**/.source
**/.next
**/.netlify
**/stats.html
*.md
LICENSE
CODEOWNERS
docker-compose.yml
infra
