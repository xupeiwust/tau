{
  // Exclude repos/ (cloned upstream repos) from all file watching, search, and extension processing.
  // Without this, extensions (oxfmt, Tailwind, Git, TypeScript) try to process 65k+ files and OOM.
  "files.watcherExclude": {
    "repos/**": true,
    "tarballs/**": true,
    "experiments/**": true
  },
  "search.exclude": {
    "repos/**": true,
    "tarballs/**": true,
    "experiments/**": true
  },
  "javascript.preferences.importModuleSpecifierEnding": "js",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "nxConsole.generateAiAgentRules": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.experimental.useTsgo": true,
  "typescript.tsserver.useSyntaxServer": "never",
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "json"],
  // Monorepo support with top-level eslint config
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "oxc.enable": true,
  "oxc.lint.enable": true,
  "oxc.configPath": ".oxlintrc.json",
  "oxc.path.oxlint": "node_modules/oxlint/dist/cli.js",
  "oxc.path.oxfmt": "node_modules/oxfmt/dist/cli.js",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.typeAware": true,
  "oxc.trace.server": "off",
  // Disabled until ESLint is fully removed. In the hybrid setup, oxlint falsely flags
  // eslint-disable comments for ESLint-only rules as unused. Re-enable to "warn" once ESLint is gone.
  "oxc.unusedDisableDirectives": "allow",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "tailwindCSS.experimental.configFile": {
    "apps/ui/app/styles/global.css": "apps/ui/**"
  },
  "tailwindCSS.files.exclude": ["repos/**", "**/node_modules/**", "**/.git/**", "**/dist/**"]
}
