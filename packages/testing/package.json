{
  "name": "@taucad/testing",
  "version": "0.0.1",
  "description": "Geometry analysis, grading, and test utilities for @taucad packages",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taucad/tau.git",
    "directory": "packages/testing"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/cjs/index.d.cts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "cad",
    "typescript"
  ],
  "author": "Richard Fontein",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./geometry": "./src/geometry/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "require": {
          "types": "./dist/cjs/index.d.cts",
          "default": "./dist/cjs/index.cjs"
        },
        "import": {
          "types": "./dist/esm/index.d.ts",
          "default": "./dist/esm/index.js"
        }
      },
      "./geometry": {
        "require": {
          "types": "./dist/cjs/geometry/index.d.cts",
          "default": "./dist/cjs/geometry/index.cjs"
        },
        "import": {
          "types": "./dist/esm/geometry/index.d.ts",
          "default": "./dist/esm/geometry/index.js"
        }
      }
    }
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1"
  },
  "devDependencies": {
    "zod": "catalog:"
  },
  "peerDependencies": {
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "imports": {
    "#*": "./src/*"
  }
}
