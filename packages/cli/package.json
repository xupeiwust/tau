{
  "name": "@taucad/cli",
  "version": "0.0.1",
  "description": "CLI for @taucad/runtime",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taucad/tau.git",
    "directory": "packages/cli"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/cjs/index.d.cts",
  "module": "./dist/esm/index.js",
  "bin": {
    "taucad": "./dist/bin/taucad.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "cad",
    "cli",
    "typescript",
    "export",
    "glb",
    "stl",
    "step"
  ],
  "author": "Richard Fontein",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "taucad": "./dist/bin/taucad.js"
    },
    "exports": {
      ".": {
        "require": {
          "types": "./dist/cjs/index.d.cts",
          "default": "./dist/cjs/index.cjs"
        },
        "import": {
          "types": "./dist/esm/index.d.ts",
          "default": "./dist/esm/index.js"
        }
      }
    }
  },
  "imports": {
    "#*": "./src/*"
  },
  "dependencies": {
    "@taucad/runtime": "workspace:*",
    "@taucad/types": "workspace:*",
    "citty": "catalog:",
    "consola": "catalog:"
  }
}
