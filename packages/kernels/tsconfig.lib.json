{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/lib",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "target": "ESNext",
    "paths": {
      "#*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../../libs/utils/tsconfig.lib.json"
    },
    {
      "path": "../../libs/types/tsconfig.lib.json"
    },
    {
      "path": "../json-schema/tsconfig.lib.json"
    },
    {
      "path": "../converter/tsconfig.lib.json"
    },
    {
      "path": "../../libs/tau-examples/tsconfig.lib.json"
    }
  ]
}
