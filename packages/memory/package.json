{
  "name": "@taucad/memory",
  "version": "0.0.1",
  "description": "Zero-dependency shared-memory primitives (SharedPool, SharedMemoryArena) over SharedArrayBuffer with Atomics",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taucad/tau.git",
    "directory": "packages/memory"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/cjs/index.d.cts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "shared-memory",
    "shared-array-buffer",
    "atomics",
    "pool",
    "lru"
  ],
  "author": "Richard Fontein",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "require": {
          "types": "./dist/cjs/index.d.cts",
          "default": "./dist/cjs/index.cjs"
        },
        "import": {
          "types": "./dist/esm/index.d.ts",
          "default": "./dist/esm/index.js"
        }
      }
    }
  },
  "imports": {
    "#*": "./src/*"
  }
}
