    "unicorn-js/better-regex": "error",
    // Disabled: not implemented in oxlint natively and adds friction without strong value.
    // TODO comments are tracked via `no-warning-comments` (as warnings) instead.
    "unicorn-js/expiring-todo-comments": "off",
    "unicorn-js/no-array-push-push": "error",
    "unicorn-js/no-for-loop": "error",
    "unicorn-js/no-named-default": "error",
    "unicorn-js/no-unnecessary-polyfills": "error",
    "unicorn-js/prefer-export-from": "error",
    "unicorn-js/prefer-switch": "error",
    "unicorn-js/prevent-abbreviations": [
      "error",
      {
        "checkFilenames": true,
        "replacements": {
          "props": false,
          "params": false,
          "env": false,
          "ref": false,
          "db": false,
          "dev": false,
          "utils": false,
          "lib": false,
          "docs": false,
          "args": false,
          "dir": { "directory": true, "direction": false },
          "dirs": { "directories": true, "directions": false }
        },
        "ignore": ["^[ij]$", "^i\\d+$"]
      }
    ],
    // Disabled: XO default. Enforcing specific import styles (default vs named vs namespace)
    // is too opinionated — the choice depends on the module's API design, not a blanket rule.
    "unicorn-js/import-style": "off",

    "node-js/no-unpublished-bin": "error",
    "node-js/no-mixed-requires": "error",
    "node-js/process-exit-as-throw": "error",
    "node-js/no-deprecated-api": "error",
    "node-js/prefer-global/buffer": "error",
    "node-js/prefer-global/console": "error",
    // Ideally ["error", "never"] to require explicit `import process from 'node:process'`,
    // but the "never" option relies on ESLint scope analysis to detect bare `process` global
    // references, which doesn't work through oxlint's jsPlugin adapter. Only "always" mode
    // (flag `require("process")`) works via jsPlugins. Revisit when oxlint supports this natively.
    "node-js/prefer-global/process": "off",
    "node-js/prefer-global/text-decoder": "error",
    "node-js/prefer-global/text-encoder": "error",
    "node-js/prefer-global/url-search-params": "error",
    "node-js/prefer-global/url": "error",
    "node-js/prefer-promises/dns": "error",
    "node-js/prefer-promises/fs": "error",

    "no-use-extend-native/no-use-extend-native": "error",

    "eslint-comments-js/disable-enable-pair": ["error", { "allowWholeFile": true }],
    "eslint-comments-js/no-aggregating-enable": "error",
    "eslint-comments-js/no-duplicate-disable": "error",
    "eslint-comments-js/no-unused-disable": "error",
    "eslint-comments-js/no-unused-enable": "error",
    // Require a description for each ESLint rule comment. This informs co-authors about the rule and why it is being applied.
    "eslint-comments-js/require-description": ["error", { "ignore": [] }],

    // --- JSDoc correctness (global) ---
    // Validates @access values are one of public|private|protected|package — catches typos like @access internal.
    "jsdoc/check-access": "error",
    // Void tags (@internal, @override, @abstract, @readonly, etc.) must have no body text.
    "jsdoc/empty-tags": "error",
    // Every @param tag must include a name — catches bare "@param - description" with no identifier.
    "jsdoc/require-param-name": "error",
    // @param names must match the function signature. checkDestructured:false skips sub-properties
    // (e.g. @param options.key) since TypeScript types document the shape.
    "jsdoc-js/check-param-names": ["error", { "checkDestructured": false }],
    // Prohibits {Type} annotations in JSDoc — TypeScript already provides types; duplicating them
    // in comments drifts out of sync and clutters IDE tooltips.
    "jsdoc-js/no-types": "error",

    "no-barrel-files/no-barrel-files": "error",

    "enforce-uint8array-arraybuffer/enforce-uint8array-arraybuffer": "error",

    "import/export": "error",
    "import/named": "error",
    "getter-return": "error",
    "no-unreachable": "error",
    // Disabled: TypeScript's compiler handles undefined variable detection far more accurately.
    // This rule produces false positives on type-level declarations, namespaces, global augmentation,
    // and ambient modules. Standard @typescript-eslint recommendation for TS projects.
    "no-undef": "off",
    "@typescript-eslint/dot-notation": "error",
    "@typescript-eslint/consistent-type-exports": "error",
    "@typescript-eslint/no-unnecessary-qualifier": "error",
    "@typescript-eslint/prefer-find": "error",
    "@typescript-eslint/prefer-optional-chain": "error",
    "@typescript-eslint/prefer-readonly": "error",
    "@typescript-eslint/prefer-string-starts-ends-with": "error",
    "@typescript-eslint/prefer-regexp-exec": "error",
    /*
     * Enforce that unnecessary conditions are not used. This improves readability and reduces perceived cyclomatic complexity.
     * For example:
     *   function bar<T>(arg: string) {
     *     // Arg can never be nullish
     *     return arg?.length; // Therefore `?.` is unnecessary
     *   }
     */
    "@typescript-eslint/no-unnecessary-condition": "error"
  },
  "overrides": [
    {
      /*
       * NestJS overrides:
       * - consistent-type-imports: off — DI requires runtime imports, type-only imports would break injection.
       * - max-params: off — Constructor dependency injection requires many parameters.
       * - new-cap exceptions — Decorators like @Injectable(), @Controller() etc. are called without `new`.
       */
      "files": [
        "apps/api/**/*.service.ts",
        "apps/api/**/*.controller.ts",
        "apps/api/**/*.module.ts",
        "apps/api/**/*.guard.ts",
        "apps/api/**/*.gateway.ts",
        "apps/api/**/*.interceptor.ts",
        "apps/api/**/*.filter.ts",
        "apps/api/**/*.pipe.ts",
        "apps/api/**/*.provider.ts",
        "apps/api/**/*.resolver.ts",
        "apps/api/**/*.middleware.ts",
        "apps/api/**/testing/*.ts"
      ],
      "rules": {
        "@typescript-eslint/consistent-type-imports": "off",
        "max-params": "off",
        "new-cap": [
          "error",
          {
            "capIsNewExceptions": [
              "Injectable",
              "Module",
              "Controller",
              "Get",
              "Post",
              "Put",
              "Delete",
              "Patch",
              "Options",
              "Head",
              "All",
              "Body",
              "Res",
              "Req",
              "Inject",
              "Global",
              "UseGuards",
              "UsePipes",
              "UseInterceptors",
              "UseFilters",
              "Catch",
              "ZodSerializerDto",
              "Sse",
              "WebSocketGateway",
              "User",
              "UseAuth"
            ]
          }
        ]
      }
    },
    {
      // Declaration files declare types/interfaces for consumers — variables are "used" by importers, not locally.
      "files": ["**/*.d.ts"],
      "rules": {
        "no-unused-vars": "off"
      },
      "plugins": ["typescript"]
    },
    {
      // Type test files use `expectTypeOf()` patterns that involve unsafe calls and void expressions by design.
      "files": ["**/*.test-d.ts"],
      "rules": {
        "@typescript-eslint/no-unsafe-call": "off",
        "@typescript-eslint/no-confusing-void-expression": "off"
      },
      "plugins": ["typescript"]
    },
    {
      // JSX component rules — React is a global variable and boolean props must use positive prefixes.
      "files": ["**/*.tsx"],
      "rules": {
        "react/react-in-jsx-scope": "off",
        /*
         * Boolean property prefixes.
         *
         * Rules:
         * - Names MUST always use the positive form of the word, never the antonym.
         *
         * Good vs Bad Examples:
         * - isEnabled, not isDisabled
         * - isVisible, not isHidden
         * - shouldShow, not shouldHide
         * - enableButton, not disableButton
         * - makeDefault, not destroyDefault
         * - withLabel, not withoutLabel
         *
         * More Usage Examples:
         * `is`: isEnabled, isActive, isSelected
         * `has`: hasValue, hasSelection, hasContent
         * `as`: asChild
         * `should`: shouldRender, shouldUpdate, shouldAnimate
         * `enable`: enableEditing, enableDragging, enableZoom
         * `make`: makeDefault, makeHandler, makeValidator
         * `with`: withTheme, withContext, withRouter, withLabel
         */
        "react-js/boolean-prop-naming": [
          "error",
          {
            "rule": "^(is|has|as|should|enable|make|with)[A-Z]([A-Za-z0-9]?)+$",
            "validateNested": true
          }
        ]
      },
      "plugins": ["react"]
    },
    {
      /*
       * Packages MUST declare all their dependencies in the package.json, as they are
       * published and consumers will not have access to the monorepo.
       * Additionally, packages require JSDoc documentation for public API surfaces.
       */
      "files": ["packages/**/*.{ts,tsx}"],
      "rules": {
        // --- JSDoc completeness (packages only) ---
        // See docs/policy/library-api-policy.md §13 for the full JSDoc standards.

        // Every function parameter must have a @param tag. Destructured params are skipped —
        // TypeScript types document the shape, so @param { a, b }: Options adds nothing.
        "jsdoc/require-param": [
          "warn",
          {
            "checkDestructured": false,
            "checkDestructuredRoots": false,
            "checkConstructors": false
          }
        ],
        // Bare @param tags with no description are useless in IDE tooltips.
        "jsdoc/require-param-description": "warn",
        // Non-void functions must have @returns so the consumer knows what they get back.
        "jsdoc/require-returns": [
          "warn",
          {
            "checkConstructors": false
          }
        ],
        // Bare @returns with no description is as unhelpful as omitting the tag entirely.
        "jsdoc/require-returns-description": "warn",
        // Validates tag names. Custom tags used by vitest and the kernels filesystem marker are allowlisted.
        "jsdoc/check-tag-names": [
          "error",
          {
            "definedTags": ["vitest-environment", "taucad/kernels/filesystem", "remarks"]
          }
        ],
        // Every exported function, class, method, type alias, and interface must have a JSDoc block.
        // This is the primary coverage gate — the remaining rules ensure that block is useful.
        "jsdoc-js/require-jsdoc": [
          "warn",
          {
            "publicOnly": true,
            "require": {
              "FunctionDeclaration": true,
              "MethodDefinition": true,
              "ClassDeclaration": true
            },
            "contexts": ["TSTypeAliasDeclaration", "TSInterfaceDeclaration"],
            "checkConstructors": false
          }
        ],
        // A JSDoc block with only tags and no description wastes the most visible tooltip real estate.
        "jsdoc-js/require-description": [
          "warn",
          {
            "contexts": [
              "FunctionDeclaration",
              "MethodDefinition",
              "ClassDeclaration",
              "TSTypeAliasDeclaration",
              "TSInterfaceDeclaration"
            ]
          }
        ],
        // Enforces the TSDoc dash separator: @param name - description. Auto-fixable.
        "jsdoc-js/require-hyphen-before-param-description": ["warn", "always"],
        // Flags descriptions that merely restate the symbol name (e.g. "The user id" on `userId`).
        // Policy §13 "Don't echo the name" — the IDE already shows the name, the description must add value.
        "jsdoc-js/informative-docs": "warn",
        // Catches empty JSDoc blocks (/** */) that satisfy require-jsdoc but carry zero information.
        "jsdoc-js/no-blank-blocks": "warn",
        // Enforces consistent tag ordering: @template → @param → @returns → @throws → @example → @see.
        // Only checks order, not spacing between groups (formatting is handled by oxfmt).
        "jsdoc-js/sort-tags": [
          "warn",
          {
            "reportTagGroupSpacing": false,
            "reportIntraTagGroupSpacing": false
          }
        ]
      },
      "plugins": ["jsdoc"]
    },
    {
      // Test files are not part of the published API — JSDoc enforcement is unnecessary.
      "files": ["packages/**/*.test.{ts,tsx}", "packages/**/*.test-d.{ts,tsx}"],
      "rules": {
        "jsdoc/require-param": "off",
        "jsdoc/require-returns": "off",
        "jsdoc/require-param-description": "off",
        "jsdoc/require-returns-description": "off",
        "jsdoc-js/require-jsdoc": "off",
        "jsdoc-js/require-description": "off",
        "jsdoc-js/require-hyphen-before-param-description": "off",
        "jsdoc-js/informative-docs": "off",
        "jsdoc-js/no-blank-blocks": "off",
        "jsdoc-js/sort-tags": "off"
      },
      "plugins": ["jsdoc"]
    },
    {
      // Package entry points need barrel file imports.
      "files": ["{packages,libs}/**/index.ts"],
      "rules": {
        "no-barrel-files/no-barrel-files": "off"
      }
    },
    {
      // CAD examples may not always follow typical conventions. For example, it's
      // easier to read d_x rather than dX, so we relax the rules here.
      "files": ["libs/tau-examples/src/kernels/**/*.ts"],
      "rules": {
        "unicorn-js/prevent-abbreviations": "warn",
        "unicorn/no-array-callback-reference": "warn",
        "@typescript-eslint/explicit-module-boundary-types": "warn",
        "@typescript-eslint/no-unsafe-assignment": "warn",
        "@typescript-eslint/no-unsafe-call": "warn",
        "@typescript-eslint/no-restricted-types": "warn",
        "@typescript-eslint/no-unsafe-return": "warn",
        "max-params": "warn"
      },
      "plugins": ["typescript"]
    },
    {
      /*
       * CJS compatibility shims deliberately check globals like `globalThis.__dirname === undefined`
       * where TypeScript types say the value is always `string`. The types are wrong — at runtime
       * these globals ARE undefined in worker/ESM contexts. Type-aware rules produce guaranteed
       * false positives here.
       */
      "files": ["**/*.cjs"],
      "rules": {
        "@typescript-eslint/no-unnecessary-condition": "off",
        "@typescript-eslint/prefer-nullish-coalescing": "off",
        "@typescript-eslint/promise-function-async": "off"
      }
    },
    {
      // CLI scripts legitimately need `process.exit()` for signaling exit codes.
      "files": ["**/scripts/**/*.mts", "**/scripts/**/*.ts"],
      "rules": {
        "unicorn/no-process-exit": "off"
      }
    },
    {
      // JS plugin files use JSDoc for types — disabling type-annotation rules that assume TypeScript.
      "files": ["**/*.js"],
      "rules": {
        "jsdoc-js/no-types": "off"
      }
    }
  ],
  "settings": {
    "jsdoc": {
      "definedTags": ["vitest-environment", "remarks"]
    }
  }
}
