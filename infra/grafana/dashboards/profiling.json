{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Profile",
      "type": "flamegraph",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "targets": [
        {
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"tau-api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Heap Allocations",
      "type": "flamegraph",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "targets": [
        {
          "profileTypeId": "memory:alloc_objects:count:space:bytes",
          "labelSelector": "{service_name=\"tau-api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 100 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{service_name=~\"$service\"} |= \"level\" | json | level = \"error\"", "refId": "A" }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 108 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{ "query": "{resource.service.name=~\"$service\"}", "refId": "A", "queryType": "traceqlSearch" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["profiling", "pyroscope"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up, service_name)",
        "current": { "text": "tau-api", "value": "tau-api" },
        "includeAll": false,
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Profiling",
  "uid": "tau-profiling"
}
