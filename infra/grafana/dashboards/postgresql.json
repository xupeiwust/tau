{
  "uid": "tau-postgresql",
  "title": "PostgreSQL",
  "tags": ["tau", "postgresql"],
  "timezone": "browser",
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, service_name)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{service_name=~\"$service\"}, instance)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "targets": [
        {
          "rawSql": "SELECT count(*) as active FROM pg_stat_activity WHERE state = 'active'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Query Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(db_client_operation_duration_count{service_name=~\"$service\"}[5m])) by (db_operation_name)",
          "legendFormat": "{{db_operation_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Transaction Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "targets": [
        {
          "rawSql": "SELECT xact_commit + xact_rollback as total FROM pg_stat_database WHERE datname = current_database()",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Query Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_bucket{service_name=~\"$service\"}[5m])) by (le, db_operation_name))",
          "legendFormat": "{{db_operation_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Deadlocks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "targets": [
        {
          "rawSql": "SELECT deadlocks FROM pg_stat_database WHERE datname = current_database()",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Table Sizes",
      "type": "table",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "targets": [
        {
          "rawSql": "SELECT schemaname, tablename, pg_total_relation_size(quote_ident(schemaname) || '.' || quote_ident(tablename)) as size FROM pg_tables WHERE schemaname NOT IN ('pg_catalog', 'information_schema') ORDER BY size DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "size" }, "properties": [{ "id": "unit", "value": "decbytes" }] }
        ]
      }
    },
    {
      "title": "Index Usage",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "targets": [
        {
          "rawSql": "SELECT schemaname, relname as tablename, indexrelname, idx_scan, idx_tup_read FROM pg_stat_user_indexes ORDER BY idx_scan DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Pending Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "db_client_connection_pending_requests{service_name=~\"$service\"}",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{service_name=~\"$service\"} |= \"level\" | json | level = \"error\"", "refId": "A" }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{ "query": "{resource.service.name=~\"$service\"}", "refId": "A", "queryType": "traceqlSearch" }]
    }
  ],
  "schemaVersion": 39
}
