  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "start": "nx run-many -t serve",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "mcp:browser": "npx -y @agentdeskai/browser-tools-mcp@1.2.0",
    "build": "nx run-many -t build",
    "extract-replicad-api": "node scripts/extract-replicad-api.ts",
    "analyze-replicad-api": "node scripts/use-extracted-api.ts",
    "ci:affected": "CI=true nx affected --targets=test,build,lint,typecheck",
    "ci:all": "CI=true nx run-many --targets=test,build,lint,typecheck",
    "$infra:comment": "The new `docker compose` command is not supported outside of Docker Desktop, so we use the old `docker-compose` command. Migrate after it's ported to the `docker` CLI.",
    "infra:up": "docker-compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker-compose -f infra/docker-compose.yml down",
    "infra:reset": "docker-compose -f infra/docker-compose.yml down -v && docker-compose -f infra/docker-compose.yml up -d",
    "infra:logs": "docker-compose -f infra/docker-compose.yml logs -f",
    "infra:logs:redis": "docker-compose -f infra/docker-compose.yml logs -f redis",
    "infra:logs:postgres": "docker-compose -f infra/docker-compose.yml logs -f postgres",
    "db:generate": "nx run api:db-generate",
    "db:migrate": "nx run api:db-migrate",
    "db:studio": "nx run api:db-studio",
    "db:push": "nx run api:db-push",
    "db:drop": "nx run api:db-drop",
    "update-license-deps": "node --import tsx scripts/update-license-deps.mts"
  },
