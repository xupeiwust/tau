{
  "copyFiles": [
    // Geist Sans TTF fonts for OpenSCAD text() rendering
    {
      "from": "./node_modules/geist/dist/fonts/geist-sans/Geist-Regular.ttf",
      "to": "src/fonts/Geist-Regular.ttf"
    },
    {
      "from": "./node_modules/geist/dist/fonts/geist-sans/Geist-Bold.ttf",
      "to": "src/fonts/Geist-Bold.ttf"
    }
  ],
  // Always overwrite files
  "whenFileExists": "overwrite"
}
