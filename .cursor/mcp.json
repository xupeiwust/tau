{
  "mcpServers": {
    "langgraph-docs-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "LangGraph:https://langchain-ai.github.io/langgraphjs/llms.txt LangChain:https://js.langchain.com/llms.txt",
        "--transport",
        "stdio"
      ]
    },
    "@magicuidesign/mcp": {
      "description": "Installing Magic UI Components. Call this when you want animations in the UI.",
      "command": "npx",
      "args": [
        "@magicuidesign/mcp@latest"
      ]
    },
    "shadcn/animate-ui": {
      "description": "Installing Animate UI Components",
      "command": "npx",
      "args": [
        "shadcn@canary",
        "registry:mcp"
      ],
      "env": {
        "REGISTRY_URL": "https://animate-ui.com/r/registry.json"
      }
    },
    "shadcn": {
      "description": "Installing Shadcn UI Components",
      "command": "npx",
      "args": [
        "shadcn@canary",
        "registry:mcp"
      ],
      "env": {
        "REGISTRY_URL": "https://raw.githubusercontent.com/shadcn-ui/ui/refs/heads/main/apps/v4/registry.json"
      }
    },
    "browser-tools": {
      "description": "Browser screenshots, debugging, and more",
      "command": "npx",
      "args": [
        "@agentdeskai/browser-tools-mcp@1.2.0"
      ]
    },
    "ai-sdk-5-migration": {
      "url": "https://ai-sdk-5-migration-mcp-server.vercel.app/api/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--isolated=true",
        "--categoryPerformance=true",
        "--categoryNetwork=true"
      ]
    }
  }
}
